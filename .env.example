# reforgedz-auth — environment

# HTTP
PORT=3050
HOST=127.0.0.1
PUBLIC_ORIGIN=https://auth.reforgedz.net

# Session cookie
COOKIE_NAME=rz_session
COOKIE_DOMAIN=.reforgedz.net
COOKIE_SECURE=true
SESSION_TTL_DAYS=7

# Ed25519 signing keys (PEM). Either point to files via *_PATH or paste inline as *_PEM.
JWT_PRIVATE_KEY_PATH=./keys/ed25519-private.pem
JWT_PUBLIC_KEY_PATH=./keys/ed25519-public.pem
# JWT_PRIVATE_KEY_PEM=
# JWT_PUBLIC_KEY_PEM=

# Database
DB_PATH=./data/auth.db

# One-time setup/reset token lifetime (hours)
SETUP_TOKEN_TTL_HOURS=24
RESET_TOKEN_TTL_HOURS=2

# Login rate limit (per IP)
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=60000

# Mail (Mailcow on EU box). Leave SMTP_HOST blank to disable email features.
SMTP_HOST=mail.reforgedz.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@reforgedz.net
SMTP_PASS=
MAIL_FROM="ReforgedZ <noreply@reforgedz.net>"

# Trust proxy (Cloudflare Tunnel sits in front). 1 = trust first hop.
TRUST_PROXY=1
